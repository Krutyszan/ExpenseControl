@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3" Style="font-family: 'Bitcount Grid Double', sans-serif;">Licznik wydatków XD</MudText>

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                <form action="/Logout" method="post" class="d-flex align-center">

                    <input type="hidden" name="ReturnUrl" value="/" />

                    <MudIconButton ButtonType="ButtonType.Submit"
                                   Icon="@Icons.Material.Filled.Logout"
                                   Color="Color.Inherit"
                                   Title="Wyloguj się" />
                </form>
            </Authorized>
        </AuthorizeView>

        <MudToggleIconButton @bind-Toggled="@_isDarkMode"
                             Icon="@Icons.Material.Filled.DarkMode" Color="Color.Inherit"
                             ToggledIcon="@Icons.Material.Filled.LightMode" ToggledColor="Color.Warning"
                             Title="Zmień motyw" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="@DrawerVariant.Mini"
               OpenMiniOnHover="true"
               ClipMode="DrawerClipMode.Always"
               Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                PANEL GŁÓWNY
            </MudNavLink>
            <MudNavLink Href="transactions" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.ReceiptLong">
                TRANSAKCJE
            </MudNavLink>

            <MudNavLink Href="stores" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Store">
                SKLEPY
            </MudNavLink>

            <MudNavLink Href="categories" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Category">
                KATEGORIE
            </MudNavLink>

            <MudNavLink Href="tags" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label">
                TAGI
            </MudNavLink>

            <MudDivider Class="my-2" />
            <MudNavLink Href="settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">
                USTAWIENIA
            </MudNavLink>
            <MudNavLink Href="about" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Info">
                O APLIKACJI
            </MudNavLink> 
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = false;
    bool _isDarkMode = false; // Domyślnie jasny, zmień na true jeśli wolisz ciemny start

    // Konfiguracja kolorów - robimy klimat "Fintech"
    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1E88E5",      // Profesjonalny niebieski (lub daj zielony "#2E7D32")
            Secondary = "#FF4081",    // Różowy akcent (dobry do FAB)
            AppbarBackground = "#1E88E5",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#90CAF9",
            Secondary = "#F48FB1",
            AppbarBackground = "#1e1e2d", // Ciemnogranatowy pasek
            Background = "#121212",       // Prawdziwa czerń
            Surface = "#1e1e2d",          // Karty trochę jaśniejsze
        }
    };

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}