@page "/about"

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">

    <MudCard Elevation="3" Class="pa-4">

        <MudCardHeader>
            <CardHeaderAvatar>
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                </MudAvatar>
            </CardHeaderAvatar>
            <CardHeaderContent>
                <MudText Typo="Typo.h6" Class="ml-3" Style="font-family: 'Bitcount Grid Double', sans-serif;">Licznik wydatków XD</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Wersja 0.2137 (minimum viable jan paweł)</MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent>
            <MudText Typo="Typo.body1" Class="mb-4">
                Aplikacja do kontrolowania budżetu domowego (albo przynajmniej jego próbowania XD). Projekt powstaje z potrzeby ogarnięcia swojego życia finansowego, a i przy okazji jest to świetna okazja do ogarnięcia nowych technologii.
            </MudText>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.subtitle2" Class="mb-2">Technologie:</MudText>
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudChip T="string" Color="Color.Info" Size="Size.Small" Icon="@Icons.Material.Filled.Code">.NET 10</MudChip>
                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Icon="@Icons.Custom.Brands.Microsoft">Blazor Server</MudChip>
                <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.Storage">EF Core & SQLite</MudChip>
                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.Psychology">Google Gemini AI</MudChip>
                <MudChip T="string" Color="Color.Dark" Size="Size.Small" Icon="@Icons.Custom.Brands.Linux">Linux LXC</MudChip>
                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.Layers">Proxmox VE</MudChip>
            </MudStack>

        </MudCardContent>

        <MudCardActions>
            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Custom.Brands.GitHub" Href="https://github.com/Krutyszan" Target="_blank">GitHub</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Custom.Brands.LinkedIn" Href="https://www.linkedin.com/in/tomasz-krutysza-9bb145122/" Target="_blank">LinkedIn</MudButton>
        </MudCardActions>

    </MudCard>
    <MudCard Elevation="3" Class ="pa-4">
        <MudCardHeader><MudText Typo="Typo.h6" Class="ml-3" Style="font-family: 'Bitcount Grid Double', sans-serif;">Do dodania:</MudText></MudCardHeader>
        <MudDivider Vertical="true" FlexItem="true" />
        <MudText Typo="Typo.body1" Class="mb-4">
            -EDYCJA NA RAZIE NIE JEST MOŻLIWA, ALE BĘDZIE XD <br />
            -TAGI <br />
            -TRACKERY KATEGORII <br />
            -SARKASTYCZNE KOMENTARZE OD AI <br />
            -PLANOWANIE BUDŻETU <br />
        </MudText>
    </MudCard>
    @*<MudText Typo="Typo.body1" Align="Align.Center" Style="display:block; opacity: 0.6;">
        V. Dzięki Tobie nauczyłem się walczyć o siebie.


    </MudText>*@
</MudContainer>