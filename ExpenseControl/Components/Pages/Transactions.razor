@page "/transactions"
@page "/"
@using ExpenseControl.Models
@using ExpenseControl.Services
@using ExpenseControl.Services.Interfaces
@inject ITransactionService Service
@inject ReceiptService ReceiptService
@inject ISnackbar Snackbar
@inject ExpenseControl.Services.Interfaces.ICurrentUserService CurrentUserService
<MudAlert Severity="Severity.Info" Class="mb-4">
    Moje ID według systemu to: <b>@(string.IsNullOrEmpty(CurrentUserService.UserId) ? "PUSTO! JESTEM DUCHEM" : CurrentUserService.UserId)</b>
</MudAlert>
<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 pb-16">
    <MudText Typo="Typo.h4" GutterBottom="true">Moje Wydatki</MudText>

    <MudTable Items="@_transactions" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="3">
        <HeaderContent>
            <MudTh></MudTh>
            <MudTh>Data</MudTh>
            <MudTh>Sklep</MudTh>
            <MudTh>Kategoria</MudTh>
            <MudTh Style="text-align:right">Kwota</MudTh>
            <MudTh>Akcje</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @if (context.Items != null && context.Items.Any())
                {
                    <MudIconButton Icon="@(_expandedRows.Contains(context.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   OnClick="@(() => ToggleDetails(context.Id))"
                                   Size="Size.Small" />
                }
            </MudTd>

            <MudTd DataLabel="Data">@context.TransactionDate.ToShortDateString()</MudTd>
            <MudTd DataLabel="Sklep"><b>@(context.Store?.Name ?? "Nieznany")</b></MudTd>
            <MudTd DataLabel="Kategoria">@(context.Store?.Category?.Name ?? "Brak")</MudTd>
            <MudTd DataLabel="Kwota" Style="text-align:right"><b>@context.TotalAmount.ToString("C2")</b></MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" />
            </MudTd>
        </RowTemplate>

        <ChildRowContent>
            @if (_expandedRows.Contains(context.Id))
            {
                <MudTr>
                    <td colspan="6" class="pa-0">
                        <MudCard Elevation="0" Class="ma-4" Style="background-color: #f8f9fa; border-left: 4px solid #1e88e5;">
                            <MudCardContent Class="pa-2">
                                <MudTable Items="@context.Items" Context="itemContext" Hover="true" Elevation="0" Dense="true">
                                    <HeaderContent>
                                        <MudTh>Produkt</MudTh>
                                        <MudTh>Cena jedn.</MudTh>
                                        <MudTh>Ilość</MudTh>
                                        <MudTh Style="text-align:right">Razem</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Produkt">@itemContext.Name</MudTd>
                                        <MudTd DataLabel="Cena jedn.">@itemContext.UnitPrice.ToString("C2")</MudTd>
                                        <MudTd DataLabel="Ilość">@itemContext.Quantity</MudTd>
                                        <MudTd DataLabel="Razem" Style="text-align:right; font-weight:bold">
                                            @((itemContext.Quantity * itemContext.UnitPrice).ToString("C2"))
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudCardContent>
                        </MudCard>
                    </td>
                </MudTr>
            }
        </ChildRowContent>
    </MudTable>

</MudContainer>

<div style="position: fixed; bottom: 20px; right: 20px; display: flex; flex-direction: column; gap: 15px; z-index: 100;">

    <MudFab Color="Color.Primary"
            StartIcon="@Icons.Material.Filled.Add"
            OnClick="OpenManualDialog"
            Label="Ręcznie" />

    <MudFileUpload T="IBrowserFile" FilesChanged="UploadFiles">
        <ActivatorContent>
            <MudFab Color="Color.Secondary"
                    StartIcon="@Icons.Material.Filled.PhotoCamera"
                    Label="Skanuj" />
        </ActivatorContent>
    </MudFileUpload>
</div>

<MudOverlay Visible="_isScanning" DarkBackground="true" Absolute="false" Style="z-index: 9999;">
    <MudStack AlignItems="AlignItems.Center">
        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h5" Color="Color.Inherit">Sztuczna Inteligencja analizuje paragon...</MudText>
        <MudText Typo="Typo.body1" Color="Color.Inherit">Proszę czekać, to zajmie chwilę.</MudText>
    </MudStack>
</MudOverlay>

<MudDialog @bind-Visible="_isManualDialogOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Dodaj wydatek ręcznie
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_manualForm">
            <MudTextField @bind-Value="_manualStoreName" Label="Nazwa Sklepu" Required="true" AutoFocus="true" />
            <MudNumericField @bind-Value="_manualAmount" Label="Kwota (PLN)" Format="N2" Required="true" Adornment="Adornment.End" AdornmentText="zł" />
            <MudDatePicker @bind-Date="_manualDate" Label="Data" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseManualDialog">Anuluj</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveManualTransaction">Zapisz</MudButton>
    </DialogActions>
</MudDialog>

@code {
    // === 7. STAN KOMPONENTU (ZMIENNE) ===
    private IEnumerable<Transaction> _transactions = new List<Transaction>();
    private bool _isLoading = true;
    private bool _isScanning = false;

    private bool _isManualDialogOpen = false;
    private MudForm _manualForm;
    private string _manualStoreName;
    private decimal _manualAmount;
    private DateTime? _manualDate = DateTime.Today;
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    // === 8. CYKL ŻYCIA ===
    // Uruchamia się raz, gdy wchodzisz na stronę. Odpala pobranie danych z bazy.
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    // Pobiera dane używając nowej metody z naszego BaseService
    private async Task LoadData()
    {
        _isLoading = true;
        _transactions = await Service.GetAllAsync(); // Zmiana ze starej nazwy!
        _isLoading = false;
    }

    // === 9. LOGIKA AI (SKANOWANIE) ===
    private async Task UploadFiles(IBrowserFile file)
    {
        if (file == null) return;

        _isScanning = true;
        StateHasChanged(); // Wymusza przerysowanie ekranu, żeby pokazać kręciołek

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);

            var aiTransaction = await ReceiptService.AnalyzeReceiptAsync(stream, file.ContentType);

            // Zapis za pomocą nowej metody z BaseService
            await Service.AddAsync(aiTransaction); // Zmiana ze starej nazwy!

            Snackbar.Add($"Zapisano paragon ze sklepu {aiTransaction.Store?.Name} na kwotę {aiTransaction.TotalAmount} PLN", Severity.Success);

            await LoadData(); // Odśwież tabelę
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Błąd AI: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isScanning = false;
            StateHasChanged(); // Schowaj kręciołek bez względu na to, czy był błąd, czy sukces
        }
    }

    // === 10. LOGIKA RĘCZNA (DIALOG) ===
    private void OpenManualDialog()
    {
        _manualStoreName = string.Empty;
        _manualAmount = 0;
        _manualDate = DateTime.Today;
        _isManualDialogOpen = true;
    }

    private void CloseManualDialog() => _isManualDialogOpen = false;

    private async Task SaveManualTransaction()
    {
        // Sprawdza, czy wypełniłeś wymagane pola
        await _manualForm.Validate();
        if (!_manualForm.IsValid) return;

        var newTrans = new Transaction
        {
            TransactionDate = _manualDate ?? DateTime.Now,
            TotalAmount = _manualAmount,
            Store = new Store
            {
                Name = _manualStoreName,
                CategoryId = 0
            }
        };

        // Zapis za pomocą nowej metody z BaseService
        await Service.AddAsync(newTrans); // Zmiana ze starej nazwy!

        Snackbar.Add("Dodano ręcznie!", Severity.Success);

        _isManualDialogOpen = false;
        await LoadData(); // Odśwież tabelę
    }

    private async Task DeleteTransaction(int id)
    {
        // Usuwanie za pomocą nowej metody z BaseService
        await Service.DeleteAsync(id); // Zmiana ze starej nazwy!

        Snackbar.Add("Usunięto pomyślnie.", Severity.Info);
        await LoadData(); // Odśwież tabelę
    }

    //Rozwijane listy
    private HashSet<int> _expandedRows = new();

    private void ToggleDetails(int transactionId)
    {
        if (_expandedRows.Contains(transactionId))
        {
            _expandedRows.Remove(transactionId); // Zwiń
        }
        else
        {
            _expandedRows.Add(transactionId); // Rozwiń
        }
    }
}