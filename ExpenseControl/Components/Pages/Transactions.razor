@page "/"
@page "/transactions"
@using ExpenseControl.Models
@using ExpenseControl.Services
@inject TransactionsService Service
@inject ReceiptService ReceiptService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudText Typo="Typo.h3" GutterBottom="true">Moje Wydatki</MudText>

    <MudPaper Class="pa-4 mb-4" Elevation="3">
        <MudText Typo="Typo.h5" Class="mb-4">Dodaj nową transakcję</MudText>

        <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true" Style="background-color: #f8f9fa;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <div>
                    <MudText Typo="Typo.subtitle2"><b>Opcja Szybka:</b> Wrzuć zdjęcie paragonu</MudText>
                    <MudText Typo="Typo.caption">Gemini Flash odczyta sklep, datę i kwotę.</MudText>
                </div>

                <MudFileUpload T="IBrowserFile" FilesChanged="UploadFiles">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.AutoAwesome">
                            Skanuj Paragon (AI)
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
            </MudStack>

            @if (isScanning)
            {
                <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Class="mt-4" />
                <MudText Typo="Typo.caption" Align="Align.Center" Class="d-block mt-1">
                    Analizuję obraz... To potrwa chwilę...
                </MudText>
            }
        </MudPaper>

        <MudForm @ref="form">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="newTransaction.StoreName"
                                  Label="Sklep / Miejsce"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Nazwa sklepu jest wymagana!" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="newTransaction.TotalAmount"
                                     Label="Kwota"
                                     Format="N2"
                                     Variant="Variant.Outlined"
                                     Adornment="Adornment.Start"
                                     AdornmentText="PLN"
                                     Min="0.01M"
                                     Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="newTransaction.Category"
                                  Label="Kategoria"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="date"
                                   Label="Data transakcji"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" Class="d-flex justify-end">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="AddTransaction"
                               StartIcon="@Icons.Material.Filled.Save"
                               Size="Size.Large">
                        Zapisz Wydatek
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudPaper>

    <MudTable Items="@transactions" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@loading" LoadingProgressColor="Color.Info" Elevation="3">
        <HeaderContent>
            <MudTh>Data</MudTh>
            <MudTh>Sklep</MudTh>
            <MudTh>Kategoria</MudTh>
            <MudTh Style="text-align:right">Kwota</MudTh>
            <MudTh>Akcje</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Data">@context.TransactionDate.ToShortDateString()</MudTd>
            <MudTd DataLabel="Sklep">@context.StoreName</MudTd>
            <MudTd DataLabel="Kategoria">@context.Category</MudTd>
            <MudTd DataLabel="Kwota" Style="text-align:right; font-weight:bold">
                @context.TotalAmount.ToString("C2")
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => DeleteTransaction(context.Id))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">Brak wydatków. Dodaj coś!</MudText>
        </NoRecordsContent>
    </MudTable>
</MudContainer>

@code {
    private List<Transaction> transactions = new();
    private Transaction newTransaction = new();
    private DateTime? date = DateTime.Today;
    private bool loading = true;
    private bool isScanning = false;
    MudForm form;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        transactions = await Service.GetAllTransactionsAsync();
        loading = false;
    }

    private async Task AddTransaction()
    {
        // 1. Walidacja formularza przed wysłaniem
        await form.Validate();
        if (!form.IsValid) return;

        // 2. Przepisanie daty
        newTransaction.TransactionDate = date ?? DateTime.UtcNow;

        // 3. Zapis
        await Service.AddTransactionAsync(newTransaction);

        Snackbar.Add("Dodano wydatek!", Severity.Success);

        // 4. Reset
        newTransaction = new Transaction();
        date = DateTime.Today;
        // Resetuje stan walidacji formularza (żeby nie świecił na czerwono po resecie)
        form.ResetValidation();

        await LoadData();
    }

    private async Task DeleteTransaction(int id)
    {
        await Service.DeleteTransactionAsync(id);
        Snackbar.Add("Usunięto!", Severity.Warning);
        await LoadData();
    }

    private async Task UploadFiles(IBrowserFile file)
    {
        if (file == null) return;

        isScanning = true;
        // Wymuszamy odświeżenie, żeby pokazał się pasek postępu
        StateHasChanged();

        try
        {
            // Limit 5MB
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);

            var recognizedTransaction = await ReceiptService.AnalyzeReceiptAsync(stream, file.ContentType);

            // Mapowanie wyników z AI do formularza
            newTransaction.StoreName = recognizedTransaction.StoreName;
            newTransaction.TotalAmount = recognizedTransaction.TotalAmount;
            newTransaction.Category = recognizedTransaction.Category;
            newTransaction.TransactionDate = recognizedTransaction.TransactionDate;

            // Aktualizacja datepickera
            date = recognizedTransaction.TransactionDate;

            Snackbar.Add("Dane z paragonu odczytane!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Błąd skanowania: {ex.Message}", Severity.Error);
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            isScanning = false;
            // Bardzo ważne: mówimy Blazorowi, że dane w formularzu się zmieniły
            StateHasChanged();
        }
    }
}