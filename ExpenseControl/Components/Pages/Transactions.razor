@page "/transactions"
@page "/"
@using ExpenseControl.Models
@using ExpenseControl.Services.Interfaces
@inject ITransactionService TransactionService

<MudAlert Severity="Severity.Info" Class="mb-4">
    Moje ID według systemu to: <b>@(string.IsNullOrEmpty(CurrentUserService.UserId) ? "PUSTO! JESTEM DUCHEM" : CurrentUserService.UserId) ,KOD DO WYWALENIA</b>
</MudAlert>

@* Odpalamy Twój silnik! Używamy @ref, żeby mieć do niego dostęp w kodzie C# *@
<BaseCrud T="Transaction" Title="Moje Wydatki" Service="@TransactionService">

    <HeaderContent>
        <MudTh>Data</MudTh>
        <MudTh>Sklep</MudTh>
        <MudTh>Kategoria</MudTh>
        <MudTh Style="text-align:right">Kwota</MudTh>
    </HeaderContent>

    <RowTemplate Context="trans">
        <MudTd DataLabel="Data">@trans.TransactionDate.ToShortDateString()</MudTd>
        <MudTd DataLabel="Sklep"><b>@(trans.Store?.Name ?? "Nieznany")</b></MudTd>
        <MudTd DataLabel="Kategoria">@(trans.Store?.Category?.Name ?? "Brak")</MudTd>
        <MudTd DataLabel="Kwota" Style="text-align:right"><b>@trans.TotalAmount.ToString("C2")</b></MudTd>
    </RowTemplate>

    <ChildRowContent Context="trans">
        @if (trans.Items != null && trans.Items.Any())
        {
            <MudTable Items="@trans.Items" Context="itemContext" Hover="true" Elevation="0" Dense="true" Class="ma-4">
                <HeaderContent>
                    <MudTh>Produkt</MudTh>
                    <MudTh>Cena jedn.</MudTh>
                    <MudTh>Ilość</MudTh>
                    <MudTh Style="text-align:right">Razem</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Produkt">@itemContext.Name</MudTd>
                    <MudTd DataLabel="Cena jedn.">@itemContext.UnitPrice.ToString("C2")</MudTd>
                    <MudTd DataLabel="Ilość">@itemContext.Quantity</MudTd>
                    <MudTd DataLabel="Razem" Style="text-align:right; font-weight:bold">
                        @((itemContext.Quantity * itemContext.UnitPrice).ToString("C2"))
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="pa-4" Color="Color.Surface">Brak szczegółów z paragonu.</MudText>
        }
    </ChildRowContent>

    @* Magia bindowania! Skoro formularz operuje na czystym 'new Transaction()', musimy upewnić się, że 'Store' istnieje *@
    <FormContent Context="trans">
        @{
            if (trans.Store == null) trans.Store = new Store();
            trans.Store.CategoryId = trans.CategoryId; // Synchronizujemy kategorię dla silnika zapisującego
        }
        <MudTextField @bind-Value="trans.Store.Name" Label="Nazwa Sklepu" Required="true" AutoFocus="true" />
        <MudNumericField @bind-Value="trans.TotalAmount" Label="Kwota (PLN)" Format="N2" Required="true" Adornment="Adornment.End" AdornmentText="zł" />

        <MudSelect T="int" @bind-Value="trans.CategoryId" Label="Kategoria" Required="true">
            @foreach (var category in _categories)
            {
                <MudSelectItem Value="@category.Id">@category.Name</MudSelectItem>
            }
        </MudSelect>

        @* Przekształcenie Daty, bo DatePicker zwraca nullable DateTime? *@
        <MudDatePicker Date="@trans.TransactionDate" DateChanged="@((DateTime? d) => trans.TransactionDate = d ?? DateTime.Now)" Label="Data" Required="true" />
    </FormContent>
</BaseCrud>

@* --- PŁYWAJĄCY PRZYCISK SKANERA AI I OVERLAY --- *@
<div style="position: fixed; bottom: 20px; right: 20px; z-index: 100;">
    <MudFileUpload T="IBrowserFile" FilesChanged="UploadFiles">
        <ActivatorContent>
            <MudFab Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PhotoCamera" Label="Skanuj Paragon" />
        </ActivatorContent>
    </MudFileUpload>
</div>

<MudOverlay Visible="_isScanning" DarkBackground="true" Absolute="false" Style="z-index: 9999;">
    <MudStack AlignItems="AlignItems.Center">
        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h5" Color="Color.Inherit">Sztuczna Inteligencja analizuje paragon...</MudText>
    </MudStack>
</MudOverlay>