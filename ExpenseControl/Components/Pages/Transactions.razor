
@page "/transactions"
@using ExpenseControl.Models
@using ExpenseControl.Services
@inject TransactionsService Service
@inject ReceiptService ReceiptService
@inject ISnackbar Snackbar
@page "/"
<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 pb-16">
    <MudText Typo="Typo.h4" GutterBottom="true">Moje Wydatki</MudText>

    <MudTable Items="@transactions" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@loading" LoadingProgressColor="Color.Info" Elevation="3">
        <HeaderContent>
            <MudTh>Data</MudTh>
            <MudTh>Sklep</MudTh>
            <MudTh>Kategoria</MudTh>
            <MudTh Style="text-align:right">Kwota</MudTh>
            <MudTh>Prod.</MudTh> <MudTh>Akcje</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Data">@context.TransactionDate.ToShortDateString()</MudTd>
            <MudTd DataLabel="Sklep">
                <MudText Typo="Typo.body2" Style="font-weight:bold">@(context.Store?.Name ?? "Nieznany")</MudText>
            </MudTd>
            <MudTd DataLabel="Kategoria">
                @(context.Store?.Category?.Name ?? "Brak")
            </MudTd>
            <MudTd DataLabel="Kwota" Style="text-align:right; font-weight:bold">
                @context.TotalAmount.ToString("C2")
            </MudTd>
            <MudTd DataLabel="Prod.">
                @if (context.Items != null && context.Items.Any())
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@context.Items.Count</MudChip>
                }
                else
                {
                    <span style="color:#ccc">-</span>
                }
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => DeleteTransaction(context.Id))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">Pusto. Kliknij + albo Aparat!</MudText>
        </NoRecordsContent>
    </MudTable>

</MudContainer>

<div style="position: fixed; bottom: 20px; right: 20px; display: flex; flex-direction: column; gap: 15px; z-index: 100;">

    <MudFab Color="Color.Primary"
            StartIcon="@Icons.Material.Filled.Add"
            OnClick="OpenManualDialog"
            Label="Ręcznie" />

    <MudFileUpload T="IBrowserFile" FilesChanged="UploadFiles">
        <ActivatorContent>
            <MudFab Color="Color.Secondary"
                    StartIcon="@Icons.Material.Filled.PhotoCamera"
                    Label="Skanuj" />
        </ActivatorContent>
    </MudFileUpload>
</div>

<MudOverlay Visible="isScanning" DarkBackground="true" Absolute="false" Style="z-index: 9999;">
    <MudStack AlignItems="AlignItems.Center">
        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h5" Color="Color.Inherit">Gemini analizuje paragon...</MudText>
        <MudText Typo="Typo.body1" Color="Color.Inherit">Nie zamykaj tej strony.</MudText>
    </MudStack>
</MudOverlay>

<MudDialog @bind-Visible="isManualDialogOpen" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Dodaj wydatek ręcznie
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="manualForm">
            <MudTextField @bind-Value="manualStoreName" Label="Nazwa Sklepu" Required="true" AutoFocus="true" />
            <MudNumericField @bind-Value="manualAmount" Label="Kwota (PLN)" Format="N2" Required="true" Adornment="Adornment.End" AdornmentText="zł" />
            <MudDatePicker @bind-Date="manualDate" Label="Data" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseManualDialog">Anuluj</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveManualTransaction">Zapisz</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Transaction> transactions = new();
    private bool loading = true;
    private bool isScanning = false;

    // Zmienne do trybu ręcznego
    private bool isManualDialogOpen = false;
    private MudForm manualForm;
    private string manualStoreName;
    private decimal manualAmount;
    private DateTime? manualDate = DateTime.Today;
    private DialogOptions dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        transactions = await Service.GetAllTransactionsAsync();
        loading = false;
    }

    // --- LOGIKA AI (SKANOWANIE) ---
    private async Task UploadFiles(IBrowserFile file)
    {
        if (file == null) return;

        isScanning = true;
        StateHasChanged(); // Pokaż overlay

        try
        {
            // Limit 10MB na zdjęcie
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);

            // 1. AI analizuje
            var aiTransaction = await ReceiptService.AnalyzeReceiptAsync(stream, file.ContentType);

            // 2. Automatyczny zapis do bazy (Fire & Forget)
            await Service.AddTransactionAsync(aiTransaction);

            Snackbar.Add($"Zapisano paragon ze sklepu {aiTransaction.Store?.Name} na kwotę {aiTransaction.TotalAmount} PLN", Severity.Success);

            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Błąd AI: {ex.Message}", Severity.Error);
        }
        finally
        {
            isScanning = false;
            StateHasChanged(); // Ukryj overlay
        }
    }

    // --- LOGIKA RĘCZNA (DIALOG) ---
    private void OpenManualDialog()
    {
        // Reset formularza
        manualStoreName = string.Empty;
        manualAmount = 0;
        manualDate = DateTime.Today;
        isManualDialogOpen = true;
    }

    private void CloseManualDialog() => isManualDialogOpen = false;

    private async Task SaveManualTransaction()
    {
        await manualForm.Validate();
        if (!manualForm.IsValid) return;

        var newTrans = new Transaction
        {
            TransactionDate = manualDate ?? DateTime.Now,
            TotalAmount = manualAmount,
            // Tworzymy obiekt Store, TransactionService sam sprawdzi czy sklep istnieje
            Store = new Store
            {
                Name = manualStoreName,
                CategoryId = 0 // Service ustawi domyślną "Inne" lub 1
            }
        };

        await Service.AddTransactionAsync(newTrans);
        Snackbar.Add("Dodano ręcznie!", Severity.Success);

        isManualDialogOpen = false;
        await LoadData();
    }

    private async Task DeleteTransaction(int id)
    {
        await Service.DeleteTransactionAsync(id);
        Snackbar.Add("Usunięto.", Severity.Info);
        await LoadData();
    }
}