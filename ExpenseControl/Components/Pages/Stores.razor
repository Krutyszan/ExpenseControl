@page "/stores"
@using ExpenseControl.Models
@using ExpenseControl.Services.Interfaces
@inject IStoreService StoreService

<BaseCrud T="Store"
          Title="Moje Sklepy"
          Service="@StoreService">

    <HeaderContent>
        <MudTh>Nazwa</MudTh>
        <MudTh>Opis</MudTh>
    </HeaderContent>
    <RowTemplate Context="cat">
        <MudTd DataLabel="Nazwa"><b>@cat.Name</b></MudTd>
        <MudTd DataLabel="Opis">@(string.IsNullOrEmpty(cat.Description) ? "—" : cat.Description)</MudTd>
    </RowTemplate>
    <FormContent Context="cat">
        <MudTextField @bind-Value="cat.Name" Label="Nazwa kategorii" Required="true" RequiredError="Nazwa jest wymagana!" AutoFocus="true" />
        <MudTextField @bind-Value="cat.Description" Label="Opis (opcjonalnie)" Lines="2" Class="mt-3" />
    </FormContent>
    <ChildRowContent Context="cat">
        <MudText Typo="Typo.body2" Color="Color.Info" Class="pa-4">
            Tutaj w przyszłości pojawi się lista subkategorii dla: <b>@cat.Name</b>.
        </MudText>
    </ChildRowContent>
</BaseCrud>