@page "/stores"
@using ExpenseControl.Models
@using ExpenseControl.Services.Interfaces
@inject IStoreService StoreService
@inject ICategoryService CategoryService

<BaseCrud T="Store" Title="Moje Sklepy" Service="@StoreService">

    <HeaderContent>
        <MudTh>Nazwa Sklepu</MudTh>
        <MudTh>Domyślna Kategoria</MudTh>
        <MudTh>Opis</MudTh>
    </HeaderContent>

    <RowTemplate Context="store">
        <MudTd DataLabel="Nazwa"><b>@store.Name</b></MudTd>

        <MudTd DataLabel="Domyślna Kategoria">
            @if (store.DefaultCategory != null)
            {
                @* STYL PIGUŁKI - identyczny jak w kategoriach *@
                <div style="@($"background-color: {store.DefaultCategory.ColorHex}; color: {store.DefaultCategory.ColorHex.GetContrastColor()}; padding: 6px 12px; border-radius: 16px; display: inline-block; font-weight: bold; font-size: 0.85rem;")">
                    @store.DefaultCategory.Emoji @store.DefaultCategory.Name
                </div>
            }
            else
            {
                <MudText Color="Color.Default" Typo="Typo.caption">Brak domyślnej</MudText>
            }
        </MudTd>

        <MudTd DataLabel="Opis">
            <MudText Typo="Typo.body2">
                @(string.IsNullOrEmpty(store.Description) ? "—" : store.Description)
            </MudText>
        </MudTd>
    </RowTemplate>

    <FormContent Context="store">
        <MudTextField @bind-Value="store.Name" Label="Nazwa sklepu" Required="true" AutoFocus="true" />

        @* Wybór kategorii *@
        <MudSelect T="int" Label="Domyślna Kategoria" @bind-Value="store.DefaultCategoryId" AnchorOrigin="Origin.BottomCenter" Class="mt-3">
            <MudSelectItem Value="0">-- Brak --</MudSelectItem>
            @foreach (var cat in _categories)
            {
                <MudSelectItem Value="@cat.Id">
                    <div class="d-flex align-center gap-2">
                        @* Mała kropka z kolorem w dropdownie *@
                        <MudAvatar Style="@($"background-color: {cat.ColorHex}; height: 20px; width: 20px; font-size: 12px;")"> </MudAvatar>
                        @cat.Emoji @cat.Name
                    </div>
                </MudSelectItem>
            }
        </MudSelect>

        <MudTextField @bind-Value="store.Description" Label="Opis (opcjonalnie)" Lines="2" Class="mt-3" />
    </FormContent>

</BaseCrud>

@code {
    private IEnumerable<Category> _categories = new List<Category>();

    protected override async Task OnInitializedAsync()
    {
        // Musimy pobrać listę kategorii, żeby wypełnić <MudSelect>
        _categories = await CategoryService.GetAllAsync();
    }
}