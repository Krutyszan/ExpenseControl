@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using ExpenseControl.Data
@using Microsoft.AspNetCore.Components.Web

@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager

<PageTitle>Logowanie</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex justify-content-center align-center mt-8">
    <MudCard Elevation="4" Class="pa-4" Style="width: 100%;">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Align="Align.Center">Zaloguj się</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
            }

            @* Ważne: FormName="login" i method="post" są niezbędne w SSR *@
            <EditForm Model="@Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                <DataAnnotationsValidator />

                @* UserAttributes name jest konieczne, by formularz HTML wiedział co wysłać *@
                <MudTextField @bind-Value="Input.Email"
                              Label="Email"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              InputType="InputType.Email"
                              UserAttributes="@(new Dictionary<string, object> { { "name", "Input.Email" } })"
                              For="@(() => Input.Email)" />

                <MudTextField @bind-Value="Input.Password"
                              Label="Hasło"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Class="mb-4"
                              UserAttributes="@(new Dictionary<string, object> { { "name", "Input.Password" } })"
                              For="@(() => Input.Password)" />

                <MudCheckBox @bind-Value="Input.RememberMe"
                             Label="Zapamiętaj mnie"
                             Color="Color.Primary"
                             UserAttributes="@(new Dictionary<string, object> { { "name", "Input.RememberMe" } })"
                             Class="mb-4" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large">
                    Zaloguj
                </MudButton>
            </EditForm>
        </MudCardContent>
        <MudCardActions Class="justify-center">
            <MudLink Href="/Account/Register">Nie masz konta? Zarejestruj się</MudLink>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private string? errorMessage;

    public async Task LoginUser()
    {
        // To wykonuje się po stronie serwera po wysłaniu POSTa
        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            Logger.LogInformation("Użytkownik zalogowany.");
            NavigationManager.NavigateTo(ReturnUrl ?? "/");
        }
        else
        {
            errorMessage = "Błędny email lub hasło.";
        }
    }

    private class InputModel
    {
        [Required(ErrorMessage = "Email jest wymagany")]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Hasło jest wymagane")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}