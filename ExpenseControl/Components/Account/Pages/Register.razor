@page "/Account/Register"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using ExpenseControl.Data
@using ExpenseControl.Services.Interfaces

@* Pozwalamy wejść niezalogowanym *@
@attribute [AllowAnonymous]
@* Upewniamy się, że działa interaktywnie *@
@rendermode InteractiveServer

@inject UserManager<ApplicationUser> UserManager
@inject IUserStore<ApplicationUser> UserStore
@inject NavigationManager NavigationManager
@* Wstrzykujemy Twój serwis inicjalizujący *@
@inject IUserInitializationService UserInitializationService

<PageTitle>Rejestracja</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex justify-content-center align-center mt-8">
    <MudCard Elevation="4" Class="pa-4" Style="width: 100%;">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Align="Align.Center">Nowe konto</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <EditForm Model="@Input" OnValidSubmit="RegisterUser">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="Input.Email"
                              Label="Email"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              For="@(() => Input.Email)"
                              InputType="InputType.Email" />

                <MudTextField @bind-Value="Input.Password"
                              Label="Hasło"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Class="mb-4"
                              For="@(() => Input.Password)" />

                <MudTextField @bind-Value="Input.ConfirmPassword"
                              Label="Potwierdź hasło"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Class="mb-4"
                              For="@(() => Input.ConfirmPassword)" />

                @if (identityErrors.Any())
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">
                        @foreach (var error in identityErrors)
                        {
                            <div>@error</div>
                        }
                    </MudAlert>
                }

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="@isBusy">
                    @if (isBusy)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Inicjalizacja konta...</MudText>
                    }
                    else
                    {
                        <MudText>Zarejestruj się</MudText>
                    }
                </MudButton>
            </EditForm>
        </MudCardContent>
        <MudCardActions Class="justify-center">
            <MudLink Href="/Account/Login">Masz już konto? Zaloguj się</MudLink>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    public InputModel Input { get; set; } = new();

    private IEnumerable<string> identityErrors = new List<string>();
    private bool isBusy;

    public async Task RegisterUser()
    {
        isBusy = true;
        identityErrors = new List<string>();

        var user = CreateUser();

        await UserStore.SetUserNameAsync(user, Input.Email, CancellationToken.None);
        var emailStore = (IUserEmailStore<ApplicationUser>)UserStore;
        await emailStore.SetEmailAsync(user, Input.Email, CancellationToken.None);

        var result = await UserManager.CreateAsync(user, Input.Password);

        if (result.Succeeded)
        {
            try
            {
                await UserInitializationService.SeedDefaultUserDataAsync(user.Id);
                NavigationManager.NavigateTo("/Account/Login");
            }
            catch (Exception ex)
            {
                identityErrors = new[] { "Konto utworzone, ale błąd inicjalizacji danych: " + ex.Message };
            }
        }
        else
        {
            identityErrors = result.Errors.Select(e => e.Description);
        }

        isBusy = false;
    }

    private ApplicationUser CreateUser()
    {
        try
        {
            return Activator.CreateInstance<ApplicationUser>();
        }
        catch
        {
            throw new InvalidOperationException($"Can't create an instance of '{nameof(ApplicationUser)}'.");
        }
    }

    public class InputModel
    {
        [Required(ErrorMessage = "Email jest wymagany")]
        [EmailAddress(ErrorMessage = "Błędny format email")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Hasło jest wymagane")]
        [StringLength(100, ErrorMessage = "Hasło musi mieć min. {2} i max {1} znaków.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Confirm password")]
        [Compare("Password", ErrorMessage = "Hasła nie pasują do siebie.")]
        public string ConfirmPassword { get; set; } = "";
    }
}